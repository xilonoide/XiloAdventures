<Window x:Class="XiloAdventures.Wpf.Common.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de"
        Icon="/appicon.ico"
        Width="440"
        MinWidth="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#222222"
        Foreground="White"
        FontSize="18"
        ShowInTaskbar="False">
    <Grid Margin="16">


        <StackPanel>
            <TextBlock Text="Xilo Adventures"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Versión 1.0"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Motor y editor de aventuras conversacionales."
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>
        </StackPanel>


    </Grid>
</Window>
