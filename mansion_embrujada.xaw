  "Quests": [
    {
      "Id": "quest_romper_maldicion",
      "Name": "Romper la Maldición",
      "Description": "La Mansión de las Sombras Eternas está atrapada en una maldición ancestral. Debes descubrir la fuente de la maldición y destruirla para liberar las almas atrapadas.",
      "IsMainQuest": true,
      "Objectives": [
        "Explorar la mansión y descubrir pistas sobre la maldición",
        "Leer el diario antiguo en el estudio",
        "Encontrar la entrada a la cripta",
        "Acceder a la cámara de ritual",
        "Destruir la gema de ónix para romper la maldición"
      ]
    },
    {
      "Id": "quest_ayudar_fantasma",
      "Name": "El Llanto de la Niña",
      "Description": "El fantasma de una niña vaga por la mansión llorando. Parece querer mostrar algo importante.",
      "IsMainQuest": false,
      "Objectives": [
        "Hablar con el fantasma de la niña",
        "Seguir sus indicaciones hasta la torre este",
        "Encontrar lo que esconde en la torre"
      ]
    },
    {
      "Id": "quest_secreto_mayordomo",
      "Name": "El Secreto del Mayordomo",
      "Description": "El espectro del mayordomo parece querer comunicarse. Quizás tenga información valiosa sobre la mansión.",
      "IsMainQuest": false,
      "Objectives": [
        "Encontrar una forma de comunicarse con el mayordomo",
        "Obtener la llave maestra que custodia",
        "Acceder al tesoro de la habitación maestra"
      ]
    }
  ],
  "Conversations": [
    {
      "Id": "conv_mayordomo",
      "Name": "Diálogo con el Mayordomo Espectral",
      "Nodes": [
        { "Id": "m1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "m2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "Ssssss... bienvenido... a esta... casa maldita...", "SpeakerName": "Mayordomo", "Emotion": "Triste" } },
        { "Id": "m3", "NodeType": "Conversation_PlayerChoice", "X": 500, "Y": 100, "Properties": { "Text1": "¿Qué sucedió aquí?", "Text2": "¿Puedes ayudarme?", "Text3": "Adiós", "Text4": "" } },
        { "Id": "m4", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 50, "Properties": { "Text": "El amo... invocó... algo terrible... todos pagamos el precio...", "SpeakerName": "Mayordomo", "Emotion": "Triste" } },
        { "Id": "m5", "NodeType": "Conversation_Branch", "X": 700, "Y": 150, "Properties": { "ConditionType": "HasFlag", "FlagName": "mayordomo_llave_dada" } },
        { "Id": "m6", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 100, "Properties": { "Text": "Ya te di todo lo que podía...", "SpeakerName": "Mayordomo", "Emotion": "Neutral" } },
        { "Id": "m7", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 200, "Properties": { "Text": "Llevo esta llave... desde hace décadas... tómala... quizás puedas acabar con esto...", "SpeakerName": "Mayordomo", "Emotion": "Triste" } },
        { "Id": "m8", "NodeType": "Conversation_Action", "X": 1100, "Y": 200, "Properties": { "ActionType": "GiveItem", "ObjectId": "llave_maestra" } },
        { "Id": "m9", "NodeType": "Conversation_Action", "X": 1300, "Y": 200, "Properties": { "ActionType": "SetFlag", "FlagName": "mayordomo_llave_dada" } },
        { "Id": "m10", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 250, "Properties": { "Text": "Que encuentres... paz...", "SpeakerName": "Mayordomo", "Emotion": "Triste" } },
        { "Id": "m11", "NodeType": "Conversation_End", "X": 1500, "Y": 150, "Properties": {} }
      ],
      "Connections": [
        { "FromNodeId": "m1", "FromPortName": "Exec", "ToNodeId": "m2", "ToPortName": "Exec" },
        { "FromNodeId": "m2", "FromPortName": "Exec", "ToNodeId": "m3", "ToPortName": "Exec" },
