    {
      "Id": "conv_fantasma_nina",
      "Name": "Diálogo con Fantasma de Niña",
      "Nodes": [
        { "Id": "n1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "n2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "*sollozos* Por favor... ayúdame... está en la torre...", "SpeakerName": "Niña", "Emotion": "Triste" } },
        { "Id": "n3", "NodeType": "Conversation_PlayerChoice", "X": 500, "Y": 100, "Properties": { "Text1": "¿Qué hay en la torre?", "Text2": "¿Por qué lloras?", "Text3": "Te ayudaré", "Text4": "" } },
        { "Id": "n4", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 50, "Properties": { "Text": "Mi... mi juguete favorito... lo dejé allí antes de que... *desaparece brevemente*", "SpeakerName": "Niña", "Emotion": "Triste" } },
        { "Id": "n5", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 150, "Properties": { "Text": "Estoy atrapada... como todos los demás... no puedo descansar...", "SpeakerName": "Niña", "Emotion": "Triste" } },
        { "Id": "n6", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 250, "Properties": { "Text": "*sonríe débilmente* Gracias... eres amable... sigue a la torre...", "SpeakerName": "Niña", "Emotion": "Neutral" } },
        { "Id": "n7", "NodeType": "Conversation_Action", "X": 900, "Y": 250, "Properties": { "ActionType": "StartQuest", "QuestId": "quest_ayudar_fantasma" } },
        { "Id": "n8", "NodeType": "Conversation_End", "X": 1100, "Y": 150, "Properties": {} }
      ],
