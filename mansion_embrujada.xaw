    {
      "Id": "conv_comerciante",
      "Name": "Diálogo con Comerciante de las Sombras",
      "Nodes": [
        { "Id": "c1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "c2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "Bienvenido, viajero. Tengo mercancías raras que podrían interesarte.", "SpeakerName": "Comerciante", "Emotion": "Neutral" } },
        { "Id": "c3", "NodeType": "Conversation_PlayerChoice", "X": 500, "Y": 100, "Properties": { "Text1": "Muéstrame tu mercancía", "Text2": "¿Qué sabes de esta mansión?", "Text3": "Adiós", "Text4": "" } },
        { "Id": "c4", "NodeType": "Conversation_Shop", "X": 700, "Y": 50, "Properties": { "ShopTitle": "Mercancías Oscuras", "WelcomeMessage": "Echa un vistazo a mis tesoros..." } },
        { "Id": "c5", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 150, "Properties": { "Text": "Esta mansión... guarda secretos que es mejor no conocer. Pero si insistes, busca en la cripta.", "SpeakerName": "Comerciante", "Emotion": "Sorprendido" } },
        { "Id": "c6", "NodeType": "Conversation_NpcSay", "X": 700, "Y": 250, "Properties": { "Text": "Vuelve cuando necesites algo...", "SpeakerName": "Comerciante", "Emotion": "Neutral" } },
        { "Id": "c7", "NodeType": "Conversation_End", "X": 900, "Y": 150, "Properties": {} }
      ],
      "Connections": [
        { "FromNodeId": "c1", "FromPortName": "Exec", "ToNodeId": "c2", "ToPortName": "Exec" },
        { "FromNodeId": "c2", "FromPortName": "Exec", "ToNodeId": "c3", "ToPortName": "Exec" },
        { "FromNodeId": "c3", "FromPortName": "Option1", "ToNodeId": "c4", "ToPortName": "Exec" },
