  "Rooms": [
    {
      "Id": "entrada_principal",
      "Name": "Entrada Principal",
      "Description": "La puerta de roble chirría al cerrarse tras de ti. La entrada está decorada con cortinajes raídos y retratos cubiertos de polvo. Una escalera se alza hacia el norte, mientras que puertas laterales conducen al este y oeste.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "norte", "DoorId": null },
        { "TargetRoomId": "biblioteca", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "comedor", "Direction": "oeste", "DoorId": null }
      ]
    },
    {
      "Id": "salon_principal",
      "Name": "Salón Principal",
      "Description": "Un vasto salón con un candelabro de cristal cubierto de telarañas. Las paredes están forradas con tapices descoloridos que parecen moverse con el viento. Al norte se ve una puerta ornamentada, al este y oeste hay corredores oscuros.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "entrada_principal", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "puerta_maestra", "Direction": "norte", "DoorId": "puerta_habitacion_maestra" },
        { "TargetRoomId": "pasillo_este", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "pasillo_oeste", "Direction": "oeste", "DoorId": null }
      ]
    },
    {
      "Id": "biblioteca",
      "Name": "Biblioteca Antigua",
      "Description": "Estanterías abarrotadas de libros polvorientos se elevan hasta el techo. Una mesa de lectura en el centro tiene velas consumidas. El olor a papel viejo y humedad impregna el aire.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "entrada_principal", "Direction": "oeste", "DoorId": null },
        { "TargetRoomId": "estudio", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "comedor",
      "Name": "Comedor Sombrío",
      "Description": "Una larga mesa de banquete se extiende por la habitación, con sillas cubiertas de polvo. Los restos de un festín olvidado yacen marchitos en platos de plata oxidada.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "entrada_principal", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "cocina", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "cocina",
      "Name": "Cocina Abandonada",
      "Description": "Ollas y sartenes oxidadas cuelgan de ganchos. Un fogón apagado domina una pared. El suelo está cubierto de platos rotos y restos de comida petrificada.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "comedor", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "despensa", "Direction": "oeste", "DoorId": "puerta_despensa" }
      ]
    },
    {
      "Id": "despensa",
      "Name": "Despensa Húmeda",
      "Description": "Estantes con frascos llenos de líquidos turbios. El aire es frío y huele a moho. Algo se mueve en las sombras del fondo.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "cocina", "Direction": "este", "DoorId": "puerta_despensa" }
      ]
    },
    {
      "Id": "estudio",
      "Name": "Estudio del Erudito",
      "Description": "Un escritorio cubierto de pergaminos y tinta seca. Diagramas arcanos adornan las paredes. Una sensación opresiva pesa sobre el lugar, como si alguien estuviera observando.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "biblioteca", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "torre_este", "Direction": "arriba", "DoorId": null }
      ]
    },
    {
      "Id": "torre_este",
      "Name": "Torre Este",
      "Description": "Una habitación circular con ventanas rotas. El viento ulula a través de las grietas. Desde aquí se puede ver el jardín marchito bajo la tormenta.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "estudio", "Direction": "abajo", "DoorId": null }
      ]
    },
    {
      "Id": "pasillo_este",
      "Name": "Pasillo Este",
      "Description": "Un corredor estrecho con cuadros de antepasados que parecen seguirte con la mirada. Las tablas del suelo crujen bajo tus pies.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "oeste", "DoorId": null },
        { "TargetRoomId": "habitacion_huespedes", "Direction": "este", "DoorId": null }
      ]
    },
    {
      "Id": "habitacion_huespedes",
      "Name": "Habitación de Huéspedes",
      "Description": "Una cama con dosel y sábanas rasgadas. Un armario antiguo se alza en una esquina. Las manchas oscuras en la alfombra sugieren una historia violenta.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "pasillo_este", "Direction": "oeste", "DoorId": null }
      ]
    },
    {
      "Id": "pasillo_oeste",
      "Name": "Pasillo Oeste",
      "Description": "Espejos agrietados reflejan distorsiones extrañas de tu figura. Una puerta al final del pasillo está cerrada con múltiples cerrojos.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "capilla", "Direction": "oeste", "DoorId": "puerta_capilla" }
      ]
    },
    {
      "Id": "capilla",
      "Name": "Capilla Profanada",
      "Description": "Bancos volcados y símbolos sagrados destrozados. Un altar de piedra manchado de negro domina el frente. El aire es denso y difícil de respirar.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "pasillo_oeste", "Direction": "este", "DoorId": "puerta_capilla" },
        { "TargetRoomId": "cripta", "Direction": "abajo", "DoorId": "puerta_cripta" }
      ]
    },
    {
      "Id": "cripta",
      "Name": "Cripta Oscura",
      "Description": "Ataúdes alineados en las paredes. Inscripciones antiguas cubren el suelo de piedra. Una presencia maligna acecha en cada rincón.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "capilla", "Direction": "arriba", "DoorId": "puerta_cripta" },
        { "TargetRoomId": "catacumbas", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "catacumbas",
      "Name": "Catacumbas Sombrías",
      "Description": "Túneles de piedra con nichos que contienen huesos antiguos. Ecos fantasmales resuenan en la distancia.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "cripta", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "camara_ritual", "Direction": "norte", "DoorId": "puerta_ritual" }
      ]
    },
    {
      "Id": "camara_ritual",
      "Name": "Cámara de Ritual",
      "Description": "Un círculo mágico grabado en el suelo brilla con una luz tenue. Velas negras medio consumidas rodean el círculo. Este es el corazón de la maldición.",
      "IsInterior": true,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "catacumbas", "Direction": "sur", "DoorId": "puerta_ritual" }
      ]
    },
    {
      "Id": "puerta_maestra",
      "Name": "Ante la Habitación Maestra",
      "Description": "Una puerta imponente de madera oscura con grabados arcanos. El aire aquí es más frío que en el resto de la mansión.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "sur", "DoorId": "puerta_habitacion_maestra" },
        { "TargetRoomId": "habitacion_maestra", "Direction": "norte", "DoorId": "puerta_interior_maestra" }
      ]
    },
    {
      "Id": "habitacion_maestra",
      "Name": "Habitación Maestra",
      "Description": "Una cama de cuatro postes con cortinas negras. Retratos de los antiguos dueños te observan. Un escritorio contiene cartas sin enviar.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "puerta_maestra", "Direction": "sur", "DoorId": "puerta_interior_maestra" },
        { "TargetRoomId": "balcon", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "balcon",
      "Name": "Balcón Azotado",
      "Description": "Un balcón de piedra expuesto a los elementos. La barandilla está rota en varios lugares. La vista del jardín muerto es desoladora.",
      "IsInterior": false,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "habitacion_maestra", "Direction": "sur", "DoorId": null }
      ]
    },
    {
      "Id": "jardin_frontal",
      "Name": "Jardín Frontal",
      "Description": "Estatuas cubiertas de musgo vigilan el camino de entrada. Las plantas están marchitas y retorcidas en formas antinaturales.",
      "IsInterior": false,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "entrada_jardin", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "entrada_jardin",
      "Name": "Entrada al Jardín",
      "Description": "Un arco de hierro herrumbrado marca la entrada. Enredaderas muertas se enroscan en los barrotes.",
      "IsInterior": false,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "jardin_frontal", "Direction": "sur", "DoorId": null }
      ]
    },
    {
      "Id": "invernadero",
      "Name": "Invernadero Roto",
      "Description": "Cristales rotos por todas partes. Plantas que alguna vez fueron exóticas ahora son deformes y amenazantes.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "jardin_trasero", "Direction": "sur", "DoorId": null }
      ]
    },
    {
      "Id": "jardin_trasero",
      "Name": "Jardín Trasero",
      "Description": "Un laberinto de setos muertos. Una fuente seca está llena de hojas podridas. El viento susurra lamentos entre los árboles.",
      "IsInterior": false,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "invernadero", "Direction": "norte", "DoorId": null },
        { "TargetRoomId": "cobertizo", "Direction": "oeste", "DoorId": "puerta_cobertizo" }
      ]
    },
    {
      "Id": "cobertizo",
      "Name": "Cobertizo del Jardinero",
      "Description": "Herramientas oxidadas cuelgan de las paredes. Un banco de trabajo está cubierto de telarañas. El olor a tierra húmeda es abrumador.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "jardin_trasero", "Direction": "este", "DoorId": "puerta_cobertizo" }
      ]
    },
    {
      "Id": "sotano",
      "Name": "Sótano Inundado",
      "Description": "Agua negra cubre el suelo hasta los tobillos. Barriles podridos flotan a la deriva. Algo se mueve bajo el agua.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "cocina", "Direction": "arriba", "DoorId": null }
      ]
    }
  ],
