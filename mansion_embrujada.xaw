{
  "Game": {
    "Id": "game",
    "Title": "La Mansión de las Sombras Eternas",
    "Theme": "mansión embrujada",
    "StartRoomId": "entrada_principal",
    "StartHour": 21,
    "StartWeather": "Tormenta",
    "MinutesPerGameHour": 6,
    "ParserDictionaryJson": "{\"verbs\": {\"examinar\": [\"inspeccionar\", \"observar\"]}, \"nouns\": {\"fantasma\": [\"espectro\", \"aparición\"], \"gema\": [\"joya\", \"piedra\", \"orbe\"]}}",
    "EncryptionKey": "M7xQ9pK2",
    "EndingText": "Has sobrevivido a la Mansión de las Sombras Eternas y roto la maldición ancestral. Pocos pueden decir lo mismo. Las almas atrapadas descansan al fin en paz.",
    "CraftingEnabled": true,
    "CombatEnabled": true,
    "MagicEnabled": true,
    "BasicNeedsEnabled": true
  },
