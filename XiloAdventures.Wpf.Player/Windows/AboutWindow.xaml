<Window x:Class="XiloAdventures.Wpf.Player.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de"
        Height="180"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#222222"
        Foreground="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Xilo Adventures - Player"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Versión 1.0"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Cliente para jugar aventuras conversacionales."
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cerrar"
                    Width="80"
                    IsDefault="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
