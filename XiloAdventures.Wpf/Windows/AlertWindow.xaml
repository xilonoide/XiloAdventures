<Window x:Class="XiloAdventures.Wpf.Windows.AlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aviso"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="400"
        MaxWidth="700"
        Background="#1E1E1E"
        Foreground="#F5F5F5">
    <Border Margin="16"
            CornerRadius="8"
            Background="#2A2A2A"
            BorderBrush="#444444"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,20"
                          MaxHeight="400">
                <StackPanel>
                    <TextBlock x:Name="MessageTextBlock"
                               TextWrapping="Wrap"
                               TextTrimming="None"
                               FontSize="14"
                               Foreground="#F5F5F5"
                               Text="Mensaje" />
                    <ContentPresenter x:Name="CustomContentPresenter"
                                      Margin="0,12,0,0"
                                      Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="OkButton"
                        Content="Aceptar"
                        Padding="15,5"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        MinWidth="80"
                        Background="#3C3C3C"
                        Foreground="#F5F5F5"
                        BorderBrush="#666666"
                        Click="OkButton_Click" />
                <Button x:Name="CancelButton"
                        Content="Cancelar"
                        Padding="15,5"
                        MinWidth="80"
                        Visibility="Collapsed"
                        Background="#3C3C3C"
                        Foreground="#F5F5F5"
                        BorderBrush="#666666"
                        IsCancel="True"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
