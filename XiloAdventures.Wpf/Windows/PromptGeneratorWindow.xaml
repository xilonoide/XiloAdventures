<Window x:Class="XiloAdventures.Wpf.Windows.PromptGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Generador de Mundos"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#2A2A2A"
        Foreground="White"
        Icon="/appicon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Generador de Mundos con IA"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Usa este prompt con ChatGPT, Claude u otra IA para generar mundos completos"
                       FontSize="12"
                       Foreground="#AAAAAA"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Configuration -->
        <Border Grid.Row="1"
                Background="#363636"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Theme -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,8">
                    <TextBlock Text="Temática de la aventura"
                               FontSize="12"
                               Foreground="#DDDDDD"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="ThemeTextBox"
                             Text="mansión embrujada"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderBrush="#555555"
                             Padding="8,6"
                             FontSize="13"
                             TextChanged="ThemeTextBox_TextChanged"/>
                </StackPanel>

                <!-- Room count -->
                <StackPanel Grid.Row="0" Grid.Column="1" Width="120">
                    <TextBlock Text="Nº de salas (aprox.)"
                               FontSize="12"
                               Foreground="#DDDDDD"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="RoomCountTextBox"
                             Text="6"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderBrush="#555555"
                             Padding="8,6"
                             FontSize="13"
                             HorizontalContentAlignment="Center"
                             PreviewTextInput="RoomCountTextBox_PreviewTextInput"
                             TextChanged="RoomCountTextBox_TextChanged"/>
                </StackPanel>

                <!-- General sliders section -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Doors slider -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock FontSize="11" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="Puertas: "/>
                            <Run x:Name="DoorsValueText" Text="2"/>
                        </TextBlock>
                        <Slider x:Name="DoorsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="2"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="DoorsSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- NPCs slider -->
                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock FontSize="11" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="NPCs: "/>
                            <Run x:Name="NpcsValueText" Text="2"/>
                        </TextBlock>
                        <Slider x:Name="NpcsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="2"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="NpcsSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Quests slider -->
                    <StackPanel Grid.Column="2" Margin="8,0,8,0">
                        <TextBlock FontSize="11" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="Misiones: "/>
                            <Run x:Name="QuestsValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="QuestsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="QuestsSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Contenedores slider -->
                    <StackPanel Grid.Column="3" Margin="8,0,0,0">
                        <TextBlock FontSize="11" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="Contenedores: "/>
                            <Run x:Name="ContainersValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="ContainersSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ContainersSlider_ValueChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Object types sliders section -->
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                           Text="Tipos de objetos:"
                           FontSize="11"
                           Foreground="#AAAAAA"
                           FontWeight="SemiBold"
                           Margin="0,8,0,4"/>

                <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Armas slider -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="⚔️ Armas: "/>
                            <Run x:Name="WeaponsValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="WeaponsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Armaduras slider -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,8">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="🛡️ Armaduras: "/>
                            <Run x:Name="ArmorsValueText" Text="0"/>
                        </TextBlock>
                        <Slider x:Name="ArmorsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="0"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Comida slider -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,8,8">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="🍎 Comida: "/>
                            <Run x:Name="FoodValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="FoodSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Bebida slider -->
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0,0,8">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="🍺 Bebidas: "/>
                            <Run x:Name="DrinksValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="DrinksSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Ropa slider -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="👕 Ropa: "/>
                            <Run x:Name="ClothingValueText" Text="0"/>
                        </TextBlock>
                        <Slider x:Name="ClothingSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="0"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Llaves slider -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="🔑 Llaves: "/>
                            <Run x:Name="KeysValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="KeysSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Textos slider -->
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,8,0">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="📜 Textos: "/>
                            <Run x:Name="TextsValueText" Text="1"/>
                        </TextBlock>
                        <Slider x:Name="TextsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>

                    <!-- Otros slider -->
                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="8,0,0,0">
                        <TextBlock FontSize="10" Foreground="#BBBBBB" Margin="0,0,0,2">
                            <Run Text="📦 Otros: "/>
                            <Run x:Name="OtherObjectsValueText" Text="2"/>
                        </TextBlock>
                        <Slider x:Name="OtherObjectsSlider"
                                Minimum="0"
                                Maximum="500"
                                Value="2"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                ValueChanged="ObjectTypeSlider_ValueChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Hint -->
                <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                           Text="💡 Ejemplos de temática: templo antiguo, nave espacial abandonada, castillo medieval, laboratorio secreto, isla desierta..."
                           FontSize="11"
                           Foreground="#888888"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- Instructions -->
        <Border Grid.Row="2"
                Background="#2E3D2E"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Foreground="#90EE90">1.</Run> Copia el prompt →
                    <Run FontWeight="SemiBold" Foreground="#90EE90">2.</Run> Pégalo en ChatGPT/Claude →
                    <Run FontWeight="SemiBold" Foreground="#90EE90">3.</Run> Descarga el archivo .xaw →
                    <Run FontWeight="SemiBold" Foreground="#90EE90">4.</Run> Ábrelo en el editor
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Prompt TextBox -->
        <TextBox x:Name="PromptTextBox"
                 Grid.Row="3"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 BorderBrush="#555555"
                 BorderThickness="1"
                 Padding="12"
                 FontFamily="Consolas"
                 FontSize="11"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Margin="0,16,0,0">
            <Button x:Name="CopyButton"
                    Content="📋 Copiar al portapapeles"
                    Height="36"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="CopyButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#5CBF60"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5CBF60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
