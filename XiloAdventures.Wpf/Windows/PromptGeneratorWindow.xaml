<Window x:Class="XiloAdventures.Wpf.Windows.PromptGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Generador de Mundos"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#2A2A2A"
        Foreground="White"
        Icon="/appicon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Generador de Mundos con IA"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Usa este prompt con ChatGPT, Claude u otra IA para generar mundos completos"
                       FontSize="12"
                       Foreground="#AAAAAA"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Instructions -->
        <Border Grid.Row="1"
                Background="#363636"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock FontSize="13" Foreground="#DDDDDD" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Foreground="#FFD700">Instrucciones:</Run>
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,8,0,0">
                    1. Copia el prompt de abajo usando el botón "Copiar al portapapeles"
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,4,0,0">
                    2. Pégalo en ChatGPT, Claude o tu IA favorita
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,4,0,0">
                    3. La IA generará un JSON con un mundo completo (salas, objetos, NPCs, scripts, etc.)
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,4,0,0">
                    4. Guarda el JSON como archivo <Run FontWeight="SemiBold">.xaw</Run> y ábrelo en el editor
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Prompt TextBox -->
        <TextBox x:Name="PromptTextBox"
                 Grid.Row="2"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 BorderBrush="#555555"
                 BorderThickness="1"
                 Padding="12"
                 FontFamily="Consolas"
                 FontSize="11"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0">
            <Button x:Name="CopyButton"
                    Content="📋 Copiar al portapapeles"
                    Height="36"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="CopyButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#5CBF60"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#5CBF60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
