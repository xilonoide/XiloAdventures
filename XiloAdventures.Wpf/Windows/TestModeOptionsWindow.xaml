<Window x:Class="XiloAdventures.Wpf.Windows.TestModeOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Opciones de modo pruebas"
        Height="280"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#222222"
        Foreground="White"
        WindowStyle="ToolWindow"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderBrush="#555555" BorderThickness="1" CornerRadius="6" Background="#222222">
        <StackPanel Margin="20" VerticalAlignment="Center">
            <TextBlock Text="Opciones del modo pruebas"
                       FontSize="16"
                       Margin="0,0,0,20"
                       TextAlignment="Center"
                       FontWeight="Bold"
                       Foreground="White"/>

            <StackPanel Margin="0,0,0,15">
                <CheckBox x:Name="SoundCheckBox"
                          Content="Sonido"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          Foreground="White"
                          Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="AiCheckBox"
                              Content="Usar IA"
                              FontSize="14"
                              VerticalContentAlignment="Center"
                              Foreground="White"/>
                    <TextBlock Text="?"
                               Margin="6,0,0,0"
                               Foreground="Yellow"
                               FontWeight="Bold"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               MouseLeftButtonUp="AiInfoIcon_MouseLeftButtonUp">
                        <TextBlock.ToolTip>
                            <TextBlock Text="Activa la IA para que el juego entienda mejor comandos complejos. Haz clic para más detalles." />
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Esta configuración se guarda con el mundo y se usará cada vez que pulses el botón de pruebas."
                       FontSize="12"
                       Foreground="#AAAAAA"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <Button x:Name="SaveButton"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="SaveButton_Click"
                    HorizontalAlignment="Stretch">
                <TextBlock Text="Guardar"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Button>
        </StackPanel>
    </Border>
</Window>
