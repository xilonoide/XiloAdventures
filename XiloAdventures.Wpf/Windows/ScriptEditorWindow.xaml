<Window x:Class="XiloAdventures.Wpf.Windows.ScriptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:XiloAdventures.Wpf.Controls"
        Title="Editor de Scripts"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="#222222"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToggleButton" x:Key="ToolbarToggle">
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#333333" Padding="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Script:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0,8,0"/>
                <TextBox x:Name="ScriptNameTextBox"
                         Width="200"
                         Background="#444444"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="6,4"
                         VerticalContentAlignment="Center"/>

                <Separator Margin="8,2" Background="#555555"/>

                <ToggleButton x:Name="ToggleGridButton"
                              Content="Grid"
                              Style="{StaticResource ToolbarToggle}"
                              IsChecked="True"
                              Click="ToggleGrid_Click"/>

                <ToggleButton x:Name="ToggleSnapButton"
                              Content="Snap"
                              Style="{StaticResource ToolbarToggle}"
                              IsChecked="True"
                              Click="ToggleSnap_Click"/>

                <Separator Margin="8,2" Background="#555555"/>

                <Button Content="Centrar"
                        Style="{StaticResource ToolbarButton}"
                        Click="CenterView_Click"/>

                <Button Content="Zoom +"
                        Style="{StaticResource ToolbarButton}"
                        Click="ZoomIn_Click"/>

                <Button Content="Zoom -"
                        Style="{StaticResource ToolbarButton}"
                        Click="ZoomOut_Click"/>

                <Button Content="Reset"
                        Style="{StaticResource ToolbarButton}"
                        Click="ResetZoom_Click"/>

                <Separator Margin="8,2" Background="#555555"/>

                <Button Content="Eliminar Seleccion"
                        Style="{StaticResource ToolbarButton}"
                        Click="DeleteSelected_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Node Palette -->
            <controls:NodePalette x:Name="NodePalette" Grid.Column="0"/>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          Background="#444444"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"/>

            <!-- Center: Script Canvas -->
            <controls:ScriptPanel x:Name="ScriptPanel" Grid.Column="2"/>

            <GridSplitter Grid.Column="3"
                          Width="4"
                          Background="#444444"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"/>

            <!-- Right Panel: Properties -->
            <Border Grid.Column="4" Background="#333333">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#444444" Padding="8,6">
                        <TextBlock Text="PROPIEDADES"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="#AAAAAA"/>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="PropertiesPanel" Margin="8"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
