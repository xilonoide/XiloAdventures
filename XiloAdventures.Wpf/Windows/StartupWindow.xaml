<Window x:Class="XiloAdventures.Wpf.Windows.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xilo Adventures - Inicio"
        Height="450"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#222222"
        Foreground="White">
    <Window.Resources>
        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#4A4A4A"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#5A5A5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#5A5A5A"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#6A6A6A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Mundos disponibles"
                       FontSize="18"
                       Margin="0,0,0,10"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
                <CheckBox x:Name="SoundCheckBox"
                          Content="Sonido"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          Margin="0,0,20,0"
                          VerticalAlignment="Center"
                          Foreground="White"/>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox x:Name="LlmCheckBox"
                              Content="Usar IA"
                              FontSize="14"
                              VerticalContentAlignment="Center"
                              VerticalAlignment="Center"
                              Foreground="White"/>
                    <TextBlock Text="?"
                               Margin="6,0,0,0"
                               Foreground="Yellow"
                               FontWeight="Bold"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               MouseLeftButtonUp="LlmInfoIcon_MouseLeftButtonUp">
                        <TextBlock.ToolTip>
                            <TextBlock Text="Activa la IA para que el juego entienda mejor comandos complejos o mal escritos. Haz clic para más detalles." />
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ListBox x:Name="WorldsList"
                 Grid.Row="1"
                 Background="#333333"
                 Foreground="White"
                 BorderBrush="#555555" />

        <UniformGrid Grid.Row="2"
                     Rows="1"
                     Columns="5"
                     Margin="0,10,0,0"
                     HorizontalAlignment="Stretch">
            <Button x:Name="NewGameButton"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="NewGameButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE109;" Margin="0,0,8,0" />
                    <TextBlock Text="Nueva partida"/>
                </StackPanel>
            </Button>
            <Button x:Name="LoadGameButton"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="LoadGameButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" Margin="0,0,8,0" />
                    <TextBlock Text="Cargar partida"/>
                </StackPanel>
            </Button>
            <Button x:Name="EditorButton"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="EditorButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" Margin="0,0,8,0" />
                    <TextBlock Text="Editor"/>
                </StackPanel>
            </Button>
            <Button x:Name="DeleteWorldButton"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="DeleteWorldButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" Margin="0,0,8,0" />
                    <TextBlock Text="Eliminar"/>
                </StackPanel>
            </Button>
            <Button x:Name="ExitButton"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="ExitButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BB;" Margin="0,0,8,0" />
                    <TextBlock Text="Salir"/>
                </StackPanel>
            </Button>
        </UniformGrid>
        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="3"
                Background="#AA000000"
                Visibility="Collapsed">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="260"
                    Background="#222222"
                    Padding="16"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock x:Name="LoadingText"
                               Text="Cargando..."
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="12"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
