<Window x:Class="XiloAdventures.Wpf.Windows.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xilo Adventures - Inicio"
        Icon="/appicon.ico"
        Height="450"
        Width="925"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#222222"
        Foreground="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Mundos disponibles"
                       FontSize="18"
                       Margin="0,0,0,10"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
                <CheckBox x:Name="SoundCheckBox"
                          Content="Sonido"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          Margin="0,0,20,0"
                          VerticalAlignment="Center"
                          Foreground="White"/>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <CheckBox x:Name="LlmCheckBox"
                              Content="Usar IA"
                              FontSize="14"
                              VerticalContentAlignment="Center"
                              VerticalAlignment="Center"
                              Foreground="White"/>
                    <TextBlock Text="?"
                               Margin="6,0,0,0"
                               Foreground="Yellow"
                               FontWeight="Bold"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               MouseLeftButtonUp="LlmInfoIcon_MouseLeftButtonUp">
                        <TextBlock.ToolTip>
                            <TextBlock Text="Activa la IA para que el juego entienda mejor comandos complejos o mal escritos. Haz clic para más detalles." />
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ListBox x:Name="WorldsList"
                 Grid.Row="1"
                 Background="#333333"
                 Foreground="White"
                 BorderBrush="#555555"
                 MouseDoubleClick="WorldsList_MouseDoubleClick" />

        <Grid Grid.Row="2"
              Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="NewGameButton"
                    Grid.Column="1"
                    Margin="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="NewGameButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Text="&#xE109;" Margin="0,0,8,0" />
                    <TextBlock Text="Nueva partida"/>
                </StackPanel>
            </Button>
            <Button x:Name="LoadGameButton"
                    Grid.Column="3"
                    Margin="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="LoadGameButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Text="&#xE8E5;" Margin="0,0,8,0" />
                    <TextBlock Text="Cargar partida"/>
                </StackPanel>
            </Button>
            <Button x:Name="EditorButton"
                    Grid.Column="5"
                    Margin="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="EditorButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Text="&#xE70F;" Margin="0,0,8,0" />
                    <TextBlock Text="Editor"/>
                </StackPanel>
            </Button>
            <Button x:Name="DeleteWorldButton"
                    Grid.Column="7"
                    Margin="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="DeleteWorldButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Text="&#xE74D;" Margin="0,0,8,0" />
                    <TextBlock Text="Eliminar"/>
                </StackPanel>
            </Button>
            <Button x:Name="ExitButton"
                    Grid.Column="9"
                    Margin="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Click="ExitButton_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Text="&#xE8BB;" Margin="0,0,8,0" />
                    <TextBlock Text="Salir"/>
                </StackPanel>
            </Button>
        </Grid>
        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="3"
                Background="#AA000000"
                Visibility="Collapsed">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="260"
                    Background="#222222"
                    Padding="16"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock x:Name="LoadingText"
                               Text="Cargando..."
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="12"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
