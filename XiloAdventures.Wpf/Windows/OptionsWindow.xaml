<Window x:Class="XiloAdventures.Wpf.Windows.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Opciones"
        Height="260" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="#222222"
        Foreground="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <GroupBox Header="Sonido" Margin="0,0,0,10">
                <StackPanel>
                    <CheckBox x:Name="SoundCheckBox"
                              Content="Sonido activado"
                              Margin="0,0,0,10"
                              Foreground="White"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="Música:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="MusicVolumeSlider"
                                Minimum="0" Maximum="10"
                                Width="180"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MusicVolumeSlider_ValueChanged"/>
                        <TextBlock x:Name="MusicVolumeLabel"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="Efectos:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="EffectsVolumeSlider"
                                Minimum="0" Maximum="10"
                                Width="180"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="EffectsVolumeSlider_ValueChanged"/>
                        <TextBlock x:Name="EffectsVolumeLabel"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Master:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="MasterVolumeSlider"
                                Minimum="1" Maximum="10"
                                Width="180"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MasterVolumeSlider_ValueChanged"/>
                        <TextBlock x:Name="MasterVolumeLabel"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <CheckBox x:Name="UseLlmCheckBox"
                          Content="Usar IA"
                          Foreground="White"/>
                <TextBlock Text="?"
                           Margin="6,0,0,0"
                           Foreground="Yellow"
                           FontWeight="Bold"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           MouseLeftButtonUp="LlmInfoIcon_MouseLeftButtonUp">
                    <TextBlock.ToolTip>
                        <TextBlock Text="La primera vez que se intente usar la IA se descargará el modelo.&#x0a;Esto puede tardar unos minutos y dará error.&#x0a;Pasados esos minutos ya funcionará la IA correctamente."/>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tamaño de fuente:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="FontSizeSlider"
                        Minimum="8" Maximum="24"
                        Width="200"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="FontSizeSlider_ValueChanged"/>
                <TextBlock x:Name="FontSizeLabel"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cerrar" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
            <Button Content="Cancelar" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
