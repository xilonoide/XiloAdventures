<Window x:Class="XiloAdventures.Wpf.Windows.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Opciones"
        Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#222222"
        Foreground="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <CheckBox x:Name="SoundCheckBox"
                      Content="Sonido activado"
                      Margin="0,0,0,10"
                      Foreground="White"/>

            <CheckBox x:Name="UseLlmCheckBox"
                      Content="Usar IA"
                      Margin="0,0,0,10"
                      Foreground="White"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tamaño de fuente:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="FontSizeSlider"
                        Minimum="8" Maximum="24"
                        Width="200"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="FontSizeSlider_ValueChanged"/>
                <TextBlock x:Name="FontSizeLabel"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cerrar" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
            <Button Content="Cancelar" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
