<Window x:Class="XiloAdventures.Wpf.Windows.DoorKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crear llave para puerta"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#222222"
        Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Puerta:" FontWeight="Bold" />
            <TextBlock x:Name="DoorNameText" Margin="0,2,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Objeto que será la llave:" FontWeight="Bold" />
            <ComboBox x:Name="ObjectCombo"
                      Margin="0,2,0,0"
                      MinWidth="240"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id" />
        </StackPanel>

        <Grid Grid.Row="2"
              Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="Aceptar"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button Grid.Column="2"
                    Style="{StaticResource CommandButtonStyle}"
                    Content="Cancelar"
                    IsCancel="True" />
        </Grid>
    </Grid>
</Window>
