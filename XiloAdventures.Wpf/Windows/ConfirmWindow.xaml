<Window x:Class="XiloAdventures.Wpf.Windows.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmar"
        Width="500"
        MinWidth="420"
        MaxWidth="720"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#222222"
        Foreground="White"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Sí"
                    Width="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="YesButton_Click"/>
            <Button Content="No"
                    Width="80"
                    IsCancel="True"
                    Click="NoButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
